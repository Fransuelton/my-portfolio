---
import { useTranslations, getLocalePath } from "../../i18n/utils";
import type { Lang } from "../../i18n/utils";
import ProjectCard from "../ui/ProjectCard.astro";
import { featuredProjects } from "../../content/projects";

const lang = (Astro.currentLocale as Lang) ?? "pt";
const t = useTranslations(lang);

const projectsPath =
  lang === "en" ? "projects" : lang === "es" ? "proyectos" : "projetos";
---

<section id="projects" class="py-20 md:py-28">
  <div class="w-full max-w-5xl mx-auto px-4 sm:px-6">
    <!-- Heading -->
    <div class="flex flex-wrap items-start justify-between gap-6 mb-12">
      <div>
        <p class="font-mono text-xs text-muted uppercase tracking-widest mb-3" aria-hidden="true">
          <span class="text-accent">$</span> {t("nav.projects").toLowerCase()}
        </p>
        <h2 class="font-mono font-bold text-text text-3xl md:text-4xl mb-2">
          {t("projects.title")}
        </h2>
        <p class="text-muted text-base">{t("projects.subtitle")}</p>
      </div>

      <a
        href={getLocalePath(lang, projectsPath)}
        class="inline-flex items-center gap-2 px-4 py-2.5 rounded-xl font-mono text-sm border border-border text-text hover:border-accent hover:text-accent transition-colors shrink-0 self-start"
      >
        {t("projects.more")}
        <span aria-hidden="true">→</span>
      </a>
    </div>

    <!-- Cards grid -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {
        featuredProjects.map((project) => (
          <ProjectCard
            name={project.name}
            description={project.descriptions[lang]}
            image={project.image}
            deployUrl={project.deployUrl}
            repositoryUrl={project.repositoryUrl}
            tech={project.tech}
            deployLabel={project.deployLabel}
            repoLabel={t("projects.repo")}
          />
        ))
      }
    </div>
  </div>
</section>
