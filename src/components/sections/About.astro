---
import { useTranslations } from "../../i18n/utils";
import type { Lang } from "../../i18n/utils";

const lang = (Astro.currentLocale as Lang) ?? "pt";
const t = useTranslations(lang);

const CV_URL =
  "https://drive.google.com/file/d/1y-HLnC2XmD5PPHmWULrOWNi-zAJfXmXZ/view?usp=sharing";
const AVATAR_URL = "https://avatars.githubusercontent.com/u/107893416?v=4";

const stack = [
  "Shopify", "Liquid", "React", "Node.js",
  "MySQL", "TypeScript", "Vue.js",
  "JavaScript", "MongoDB", "Git",
];
const VISIBLE = 7;
const overflow = stack.length - VISIBLE;

const stats = [
  { value: "+3",   label: t("about.stat.years") },
  { value: "+90",  label: t("about.stat.projects") },
  { value: "+5",   label: t("about.stat.clients") },
  { value: "100%", label: t("about.stat.focus") },
];
---

<section id="about" class="py-20 md:py-28">
  <div class="w-full max-w-5xl mx-auto px-4 sm:px-6">
    <div class="bg-surface border border-border rounded-2xl p-8 md:p-12 reveal">
      <div class="flex flex-col md:flex-row gap-10 items-center md:items-start">
        <!-- Photo -->
        <div class="shrink-0">
          <img
            src={AVATAR_URL}
            alt={t("about.photo.alt")}
            width="192"
            height="192"
            loading="lazy"
            decoding="async"
            class="rounded-2xl w-40 h-40 md:w-48 md:h-48 object-cover border-2 border-border"
          />
        </div>

        <!-- Info -->
        <div class="flex flex-col gap-6 flex-1">
          <!-- Section label -->
          <p class="font-mono text-xs text-muted uppercase tracking-widest" aria-hidden="true">
            <span class="text-accent">$</span> {t("nav.about").toLowerCase()}
          </p>

          <h2 class="font-mono font-bold text-text text-2xl md:text-3xl leading-snug -mt-2">
            {t("about.title")}
          </h2>

          <p class="text-muted leading-relaxed text-sm sm:text-base">
            {t("about.description")}
          </p>

          <!-- Stack badges -->
          <div class="flex flex-wrap gap-2" aria-label="Tech stack">
            {stack.slice(0, VISIBLE).map((item) => (
              <span class="font-mono text-xs px-2.5 py-1 rounded-lg bg-card border border-border text-muted hover:border-accent hover:text-accent transition-colors cursor-default">
                {item}
              </span>
            ))}
            {overflow > 0 && (
              <span
                class="font-mono text-xs px-2.5 py-1 rounded-lg bg-card border border-border text-accent cursor-default"
                title={stack.slice(VISIBLE).join(", ")}
              >
                +{overflow}
              </span>
            )}
          </div>

          <!-- Stats grid -->
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 pt-2 border-t border-border">
            {stats.map(({ value, label }) => (
              <div class="flex flex-col gap-0.5">
                <span class="font-mono font-bold text-text text-2xl sm:text-3xl leading-none">
                  {value}
                </span>
                <span class="text-muted text-xs leading-snug">{label}</span>
              </div>
            ))}
          </div>

          <!-- CV button -->
          <div>
            <a
              href={CV_URL}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl font-mono text-sm font-semibold bg-accent text-[#0a0a0a] hover:bg-accent-dim transition-all duration-200 hover:-translate-y-0.5"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="15"
                height="15"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                aria-hidden="true"
              >
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                <polyline points="14 2 14 8 20 8"/>
                <line x1="16" y1="13" x2="8" y2="13"/>
                <line x1="16" y1="17" x2="8" y2="17"/>
                <polyline points="10 9 9 9 8 9"/>
              </svg>
              {t("about.cv")}
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
