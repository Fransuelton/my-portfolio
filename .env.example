# Public API base URL — exposed to the browser (Astro PUBLIC_ prefix required)
# Local development: http://localhost:3001
# Production: https://your-backend-url.com
PUBLIC_API_URL=http://localhost:3001

# Cloudflare Web Analytics beacon token
# Get it: Cloudflare Dashboard → Web Analytics → Sites → Manage site → "Get JavaScript Snippet"
# Leave empty in local dev — analytics only loads when this var is set (build-time injection)
PUBLIC_CF_ANALYTICS_TOKEN=
